{
  "compilerOptions": {
    "incremental": true,
    "module": "commonjs",
    "target": "es2020",
    "rootDir": "",
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "types": [
      "@types/jest"
    ],
    "strictNullChecks": false
  },
  "include": [
    "src/**/*.ts"
  ]
}